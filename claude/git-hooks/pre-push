#!/usr/bin/env bash
# Git pre-push hook: block pushes to main or master
while read -r local_ref local_sha remote_ref remote_sha; do
  if echo "$remote_ref" | grep -qE '\b(main|master)\b'; then
    echo "ERROR: Direct pushes to main/master are not allowed. Use a feature branch." >&2
    exit 1
  fi
done
exit 0
