{
    "statusLine": {
        "type": "command",
        "command": "bash ~/.claude/statusline.sh",
        "padding": 2
    },
    "skipDangerousModePermissionPrompt": true,
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash ~/.claude/hooks/no-push-main.sh"
                    }
                ]
            }
        ]
    }
}